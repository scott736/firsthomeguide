# ────────────────────────────────────────────────────────────────────
# FirstHomeGuide.ca — environment variables
# Copy to `.env` and fill in values for local development.
# Production values are configured in Vercel project settings.
# ────────────────────────────────────────────────────────────────────

# ── Elastic Email (transactional email) ─────────────────────────────
# Required. Used by /api/share-article, Nylas booking emails, etc.
# Obtain from: https://app.elasticemail.com/api/settings/apikeys
ELASTIC_EMAIL_API_KEY=

# ── Nylas (calendar + "Book a Call" scheduling) ─────────────────────
# Required for /book-a-call and /api/nylas/*
# Obtain from: https://dashboard-v3.nylas.com
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
# Optional — defaults to https://api.us.nylas.com
NYLAS_API_URI=
# Used to verify incoming webhook signatures
NYLAS_WEBHOOK_SECRET=

# ── Supabase (auth / persisted data — currently wired but unused) ───
# Safe to leave blank; isSupabaseConfigured() will return false.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Upstash Redis (rate limiting + Nylas grant cache) ───────────────
# Optional for local dev — falls back to in-memory rate limiting.
# Obtain from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Astro site origin (used by API routes for absolute URLs) ────────
# Optional — falls back to the incoming request origin.
SITE=https://firsthomeguide.ca

# ── Contact form destination ────────────────────────────────────────
# Where /api/contact submissions are delivered. Can be any address you
# actually read (personal Gmail, forwarder, etc.) — submitter's address
# is set as the reply-to so you can reply from any client.
# Defaults to bookings@firsthomeguide.ca if unset.
CONTACT_INBOX=
