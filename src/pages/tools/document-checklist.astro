---
import DocumentChecklist from '@/components/sections/document-checklist';
import LendCityCtaBanner from '@/components/sections/lendcity-cta-banner';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Document Checklist — FirstHomeGuide.ca"
  description="Complete checklist of documents needed for your mortgage application and home purchase. Track your progress through every stage of the Canadian home buying process."
>
  <section class="section-padding pb-0">
    <div class="container max-w-screen-xl">
      <a
        href="/tools"
        class="text-muted-foreground hover:text-foreground mb-4 inline-flex items-center gap-1 text-sm transition-colors"
      >
        &larr; All Tools
      </a>
    </div>
  </section>

  <DocumentChecklist client:load />

  <section class="section-padding pt-0">
    <div class="container max-w-screen-xl">
      <LendCityCtaBanner
        client:visible
        headline="We handle the paperwork"
        description="Our concierge team collects, reviews, and submits all your documents — so nothing gets missed."
      />
    </div>
  </section>
</DefaultLayout>
