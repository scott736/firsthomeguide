---
import CanadaMapExplorer from '@/components/sections/canada-map-explorer';
import LendCityCtaBanner from '@/components/sections/lendcity-cta-banner';
import ProgramsContent from '@/components/sections/programs-content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Programs by Province — Interactive Map — FirstHomeGuide.ca"
  description="Explore an interactive map of Canada to find every federal and provincial first-time home buyer program you qualify for. Province-specific incentives, rebates, and savings."
>
  <section class="pt-8 md:pt-12 lg:pt-16 pb-0">
    <div class="container max-w-screen-xl">
      <a
        href="/tools"
        class="text-muted-foreground hover:text-foreground mb-2 inline-flex items-center gap-1 text-sm transition-colors"
      >
        &larr; All Tools
      </a>
    </div>
  </section>

  <CanadaMapExplorer client:load />

  <ProgramsContent />

  <section class="section-padding pt-0">
    <div class="container max-w-screen-xl">
      <LendCityCtaBanner
        client:visible
        headline="Find every program you qualify for"
        description="Our team knows every federal and provincial program inside out. Book a free call and we'll match you with everything available."
      />
    </div>
  </section>

  <section class="section-padding pt-8">
    <div class="container max-w-screen-xl">
      <h2 class="mb-3 text-xl font-semibold tracking-tight">Learn more</h2>
      <ul class="text-muted-foreground space-y-2 text-sm leading-relaxed">
        <li>Explore <a href="/guide/4-government-programs/1-federal-programs/" class="text-foreground underline underline-offset-4 hover:text-chart-1">federal programs in detail</a> — full eligibility rules, contribution strategies, and how to claim each one.</li>
        <li>See the <a href="/guide/4-government-programs/7-program-comparison/" class="text-foreground underline underline-offset-4 hover:text-chart-1">complete program comparison table</a> with stacking examples for every province.</li>
        <li>Learn how the <a href="/guide/2-saving-smart/1-fhsa/" class="text-foreground underline underline-offset-4 hover:text-chart-1">FHSA</a> and <a href="/guide/2-saving-smart/2-rrsp-hbp/" class="text-foreground underline underline-offset-4 hover:text-chart-1">RRSP Home Buyers' Plan</a> work together to maximize your down payment.</li>
      </ul>
    </div>
  </section>
</DefaultLayout>
