---
import ComparisonTools from '@/components/sections/comparison-tools';
import LendCityCtaBanner from '@/components/sections/lendcity-cta-banner';
import ComparisonToolsContent from '@/components/sections/tool-content/comparison-tools-content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Rent vs Buy, FHSA vs RRSP, Fixed vs Variable — FirstHomeGuide.ca"
  description="Compare renting versus buying, FHSA versus RRSP Home Buyers' Plan, and fixed versus variable mortgage rates. Side-by-side Canadian calculators for first-time home buyers."
>
  <section class="pt-8 md:pt-12 lg:pt-16 pb-0">
    <div class="container max-w-screen-xl">
      <a
        href="/tools"
        class="text-muted-foreground hover:text-foreground mb-2 inline-flex items-center gap-1 text-sm transition-colors"
      >
        &larr; All Tools
      </a>
    </div>
  </section>

  <div class="tool-subpage">
    <ComparisonTools client:load />
  </div>

  <ComparisonToolsContent client:visible />

  <section class="section-padding pt-0">
    <div class="container max-w-screen-xl">
      <LendCityCtaBanner client:visible />
    </div>
  </section>
</DefaultLayout>
