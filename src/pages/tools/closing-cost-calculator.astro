---
import ClosingCostCalculator from '@/components/sections/closing-cost-calculator';
import LendCityCtaBanner from '@/components/sections/lendcity-cta-banner';
import ShareResults from '@/components/sections/share-results';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Closing Cost Calculator — FirstHomeGuide.ca"
  description="Estimate your total closing costs including legal fees, land transfer tax, PST on CMHC insurance, and more. Province-specific calculations for Canadian first-time home buyers."
>
  <section class="pt-8 md:pt-12 lg:pt-16 pb-0">
    <div class="container max-w-screen-xl">
      <a
        href="/tools"
        class="text-muted-foreground hover:text-foreground mb-2 inline-flex items-center gap-1 text-sm transition-colors"
      >
        &larr; All Tools
      </a>
    </div>
  </section>

  <div class="tool-subpage">
    <ClosingCostCalculator client:load />
  </div>

  <section class="pb-4 pt-0">
    <div class="container max-w-screen-xl flex justify-end">
      <ShareResults
        client:load
        title="Closing Cost Calculator Results"
        summary="Estimate closing costs including legal fees, land transfer tax, and total cash needed — FirstHomeGuide.ca"
        toolUrl="/tools/closing-cost-calculator"
      />
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="container max-w-screen-xl">
      <LendCityCtaBanner
        client:visible
        headline="No surprises at closing"
        description="Our concierge team walks you through every cost and coordinates your entire closing process — book a free call to get started."
      />
    </div>
  </section>

  <section class="section-padding pt-8">
    <div class="container max-w-screen-xl">
      <h2 class="mb-3 text-xl font-semibold tracking-tight">Learn more</h2>
      <ul class="text-muted-foreground space-y-2 text-sm leading-relaxed">
        <li>Read our <a href="/guide/7-closing-the-deal/1-closing-costs-overview/" class="text-foreground underline underline-offset-4 hover:text-chart-1">closing costs overview</a> to understand why these costs surprise so many first-time buyers.</li>
        <li>See a <a href="/guide/7-closing-the-deal/2-cost-breakdown/" class="text-foreground underline underline-offset-4 hover:text-chart-1">detailed cost breakdown</a> of every fee you should plan for, from legal fees to utility adjustments.</li>
        <li>Learn how <a href="/guide/7-closing-the-deal/3-land-transfer-tax/" class="text-foreground underline underline-offset-4 hover:text-chart-1">land transfer tax</a> is calculated in your province — usually your single largest closing cost.</li>
      </ul>
    </div>
  </section>
</DefaultLayout>
