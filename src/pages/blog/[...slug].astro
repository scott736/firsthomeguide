---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import DefaultLayout from '@/layouts/DefaultLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<DefaultLayout
  title={`${post.data.title} — FirstHomeGuide.ca`}
  description={post.data.description}
>
  <article class="section-padding container max-w-3xl">
    <a
      href="/blog"
      class="text-muted-foreground hover:text-foreground text-sm underline underline-offset-4"
    >
      &larr; All posts
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
        <time datetime={post.data.pubDate.toISOString()}>
          {dateFormatter.format(post.data.pubDate)}
        </time>
        {post.data.updatedDate && (
          <>
            <span>&middot;</span>
            <span>Updated {dateFormatter.format(post.data.updatedDate)}</span>
          </>
        )}
        {post.data.tags.length > 0 && (
          <>
            <span>&middot;</span>
            <span>{post.data.tags.join(', ')}</span>
          </>
        )}
      </div>
      <h1 class="mt-3 text-4xxl leading-tight tracking-tight md:text-5xl">
        {post.data.title}
      </h1>
      <p class="text-muted-foreground mt-3 text-sm">By {post.data.author}</p>
    </header>

    <div
      class="prose-blog mt-10 max-w-none leading-relaxed [&_a]:text-foreground [&_a]:underline [&_a]:underline-offset-4 [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:mb-2 [&_h3]:text-xl [&_h3]:font-semibold [&_li]:my-1 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:my-4 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6"
    >
      <Content />
    </div>
  </article>
</DefaultLayout>
