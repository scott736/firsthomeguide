---
export const prerender = false;

import { SchedulingWidgetWithBoundary } from '@/components/scheduling/scheduling-with-boundary';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { services, teamMembers } from '@/lib/nylas/config';
---

<DefaultLayout
  title="Book a Free Call — FirstHomeGuide.ca"
  description="Book a free consultation with a licensed LendCity mortgage professional. Get expert guidance on your first home purchase."
  noindex
>
  <section class="section-padding">
    <div class="container max-w-screen-xl">
      <div class="text-center mb-10">
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Book a Free Call</h1>
        <p class="mt-3 text-lg text-muted-foreground max-w-2xl mx-auto">
          Speak with a licensed mortgage professional about your first home purchase. No obligation, no pressure — just expert guidance.
        </p>
      </div>

      <SchedulingWidgetWithBoundary
        client:load
        services={services.filter(s => s.id !== 'strategy-call')}
        teamMembers={teamMembers.filter(m => !m.personalOnly)}
        initialServiceId="owner-occupied"
        initialRegion="canada"
      />
    </div>
  </section>
</DefaultLayout>
