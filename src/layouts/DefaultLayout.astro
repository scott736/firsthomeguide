---
import BaseHead from '@/components/BaseHead.astro';
import { FloatingCta } from '@/components/floating-cta';
import Footer from '@/components/layout/footer';
import { Navbar18 } from '@/components/navbar18';

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body
    class={`min-h-screen relative antialiased flex flex-col [--header-height:calc(var(--spacing)*17)]`}
  >
    {/* Background Blur */}
    <div
      class="bg-background/10 absolute inset-0 z-[-2]"
    >
    </div>
    {/* Noise Background */}
    <div
      class="absolute inset-0 z-[-1] size-full opacity-70 mix-blend-overlay dark:md:opacity-100"
      style={{
        background: `url(/images/noise.webp) lightgray 0% 0% / 83.69069695472717px 83.69069695472717px repeat`,
      }}
    >
    </div>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Navbar18 client:load currentPage={currentPath} />
    <main id="main-content" class="flex-1"><slot /></main>
    <Footer client:visible currentPage={currentPath} />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
    <FloatingCta client:idle />
  </body>
</html>
