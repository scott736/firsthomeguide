---
/**
 * Structured Data (JSON-LD) component for SEO and AI citability.
 * Uses the @graph pattern with @id cross-references per Google best practices.
 * Renders Organization, WebSite, Course, FAQPage, HowTo, CollectionPage,
 * SoftwareApplication, WebApplication, AboutPage, and BreadcrumbList schemas.
 */

import { LENDCITY } from '@/lib/lendcity';

interface Props {
  type?: 'home' | 'guide' | 'tools' | 'tool-page' | 'about' | 'page';
  title?: string;
  description?: string;
  toolSlug?: string;
}

const { type = 'home', title, description, toolSlug } = Astro.props;
const siteUrl = 'https://firsthomeguide.ca';

const telephoneE164 = `+${LENDCITY.phone.replace(/\D/g, '')}`;

const graph: Record<string, unknown>[] = [];

// --- Organization (always included) ---
graph.push({
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'FirstHomeGuide.ca',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    '@id': `${siteUrl}/#logo`,
    url: `${siteUrl}/layout/logo-light.svg`,
    contentUrl: `${siteUrl}/layout/logo-light.svg`,
    caption: 'FirstHomeGuide.ca',
  },
  image: { '@id': `${siteUrl}/#logo` },
  description: 'Free, independent education resource for first-time home buyers in Canada.',
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
    sameAs: 'https://en.wikipedia.org/wiki/Canada',
  },
  knowsAbout: [
    'First-time home buying in Canada',
    'First Home Savings Account (FHSA)',
    'RRSP Home Buyers\' Plan',
    'CMHC mortgage insurance',
    'Canadian mortgage rates',
    'Provincial home buyer programs',
    'Closing costs in Canada',
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: LENDCITY.streetAddress,
    addressLocality: LENDCITY.city,
    addressRegion: LENDCITY.provinceCode,
    postalCode: LENDCITY.postalCode,
    addressCountry: LENDCITY.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: telephoneE164,
    contactType: 'customer service',
    areaServed: 'CA',
    availableLanguage: 'English',
  },
  sameAs: [
    'https://twitter.com/FirstHomeGuideCA',
    'https://www.lendcity.ca',
  ],
  parentOrganization: {
    '@type': 'Organization',
    name: 'LendCity',
    url: 'https://www.lendcity.ca',
    description: 'Licensed Mortgage Professionals under Mortgage Architects',
  },
});

// --- WebSite (home page only) ---
if (type === 'home') {
  graph.push({
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: siteUrl,
    name: 'FirstHomeGuide.ca',
    description: 'The most comprehensive free resource for first-time home buyers in Canada.',
    publisher: { '@id': `${siteUrl}/#organization` },
    inLanguage: 'en-CA',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/guide/?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', 'h2', '.hero-content', '[role="note"]'],
    },
  });
}

// --- Course (home + guide pages) ---
if (type === 'home' || type === 'guide') {
  graph.push({
    '@type': 'Course',
    '@id': `${siteUrl}/guide/#course`,
    name: 'First-Time Home Buyer Guide for Canada',
    description: 'A free, comprehensive 8-module course covering everything Canadian first-time home buyers need to know — from financial readiness to closing day and beyond.',
    provider: { '@id': `${siteUrl}/#organization` },
    url: `${siteUrl}/guide/`,
    educationalLevel: 'Beginner',
    isAccessibleForFree: true,
    inLanguage: 'en-CA',
    numberOfCredits: 0,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CAD',
      category: 'Free',
    },
    audience: {
      '@type': 'EducationalAudience',
      educationalRole: 'student',
      audienceType: 'First-time home buyers in Canada',
    },
    hasCourseInstance: {
      '@type': 'CourseInstance',
      courseMode: 'online',
      courseWorkload: 'PT2H',
    },
    syllabusSections: [
      { '@type': 'Syllabus', name: 'Module 1: Are You Ready to Buy?', position: 1, url: `${siteUrl}/guide/1-are-you-ready/1-first-time-buyer/` },
      { '@type': 'Syllabus', name: 'Co-Buying Guide', position: 2, url: `${siteUrl}/guide/1-are-you-ready/6-co-buying/` },
      { '@type': 'Syllabus', name: 'Module 2: Saving Smart — FHSA, RRSP HBP & More', position: 3, url: `${siteUrl}/guide/2-saving-smart/1-fhsa/` },
      { '@type': 'Syllabus', name: 'Module 3: Down Payments & Mortgage Basics', position: 4, url: `${siteUrl}/guide/3-down-payments-mortgages/1-down-payment-rules/` },
      { '@type': 'Syllabus', name: 'Self-Employed Buyers', position: 5, url: `${siteUrl}/guide/3-down-payments-mortgages/8-self-employed/` },
      { '@type': 'Syllabus', name: 'Module 4: Government Programs by Province', position: 6, url: `${siteUrl}/guide/4-government-programs/1-federal-programs/` },
      { '@type': 'Syllabus', name: 'Territories (Yukon, NWT, Nunavut)', position: 7, url: `${siteUrl}/guide/4-government-programs/8-territories/` },
      { '@type': 'Syllabus', name: 'Module 5: Finding a Home', position: 8, url: `${siteUrl}/guide/5-finding-a-home/1-working-with-realtor/` },
      { '@type': 'Syllabus', name: 'Building Your Team', position: 9, url: `${siteUrl}/guide/5-finding-a-home/0-your-team/` },
      { '@type': 'Syllabus', name: 'Pre-Construction & New Builds', position: 10, url: `${siteUrl}/guide/5-finding-a-home/7-new-construction/` },
      { '@type': 'Syllabus', name: 'Module 6: Making an Offer', position: 11, url: `${siteUrl}/guide/6-making-an-offer/1-purchase-agreement/` },
      { '@type': 'Syllabus', name: 'Module 7: Closing the Deal', position: 12, url: `${siteUrl}/guide/7-closing-the-deal/1-closing-costs-overview/` },
      { '@type': 'Syllabus', name: 'Module 8: Life After Closing', position: 13, url: `${siteUrl}/guide/8-life-after-closing/1-emergency-fund/` },
      { '@type': 'Syllabus', name: 'Glossary of Home-Buying Terms', position: 14, url: `${siteUrl}/guide/glossary/` },
      { '@type': 'Syllabus', name: 'Frequently Asked Questions', position: 15, url: `${siteUrl}/guide/faq/` },
    ],
  });
}

// --- FAQPage (home page only) ---
if (type === 'home') {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${siteUrl}/#faq`,
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much do I need for a down payment in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The minimum down payment in Canada is 5% on the first $500,000 of the purchase price, 10% on the portion between $500,000 and $999,999, and 20% on homes priced at $1 million or more. CMHC mortgage insurance is required when the down payment is below 20%.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the First Home Savings Account (FHSA)?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The FHSA is a registered savings account that lets first-time home buyers save up to $40,000 ($8,000 per year) with tax-deductible contributions and tax-free withdrawals when used to purchase a qualifying first home. It combines the best tax features of the RRSP and TFSA.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much can I withdraw from my RRSP to buy a home?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Through the RRSP Home Buyers\' Plan (HBP), you can withdraw up to $60,000 per person to buy your first home. Couples can withdraw up to $120,000 combined. The withdrawal must be repaid to your RRSP over 15 years starting the second year after withdrawal.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the mortgage stress test in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The mortgage stress test requires all federally regulated lenders to qualify borrowers at the higher of their contract rate plus 2% or the Bank of Canada\'s qualifying rate (currently 5.25%). This ensures borrowers can handle potential interest rate increases.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need mortgage insurance in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, mortgage insurance (from CMHC, Sagen, or Canada Guaranty) is required if your down payment is less than 20% of the purchase price. Premiums range from 2.4% to 4.0% of the mortgage amount and are added to your mortgage balance.',
        },
      },
      {
        '@type': 'Question',
        name: 'What are the typical closing costs when buying a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Closing costs in Canada typically range from 1.5% to 4% of the purchase price. Major costs include land transfer tax (varies by province), legal fees ($1,500\u2013$2,500), title insurance ($300\u2013$500), home inspection ($400\u2013$600), and property tax/utility adjustments.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the Home Buyers\' Tax Credit (HBTC)?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The HBTC is a federal non-refundable tax credit of $1,500 (calculated as $10,000 \u00d7 15%) available to first-time home buyers. You claim it on line 31270 of your income tax return for the year you purchased your qualifying home.',
        },
      },
      {
        '@type': 'Question',
        name: 'What credit score do I need to buy a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A credit score of 680 or higher is ideal for getting the best mortgage rates. The minimum to qualify is typically 600 for insured mortgages, though some lenders may accept lower scores with compensating factors like a larger down payment.',
        },
      },
      {
        '@type': 'Question',
        name: 'Should I choose a fixed or variable mortgage rate?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Fixed rates offer payment certainty over your mortgage term, while variable rates have historically been cheaper over time but carry rate-change risk. Your choice depends on your risk tolerance, financial stability, and the current interest rate environment.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I combine the FHSA and RRSP Home Buyers\' Plan?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, you can use both the FHSA and the RRSP HBP for the same home purchase. This lets you access up to $100,000 per person ($40,000 FHSA + $60,000 HBP) tax-free for your down payment. Couples combining both accounts can access up to $200,000.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I buy a home with a partner or friend?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, co-buying is increasingly common. Key decisions include choosing an ownership structure (joint tenancy vs. tenants in common), drafting a co-ownership agreement with a lawyer, and understanding that both parties are jointly liable for the full mortgage.',
        },
      },
      {
        '@type': 'Question',
        name: 'How does buying pre-construction work in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'You sign an Agreement of Purchase and Sale with the builder, pay deposits on a schedule (typically 15\u201320% total over several months), wait for construction (1\u20134 years), then close once the building is registered. Tarion warranty protects buyers in Ontario. Prices are locked in at signing but closing costs may change.',
        },
      },
      {
        '@type': 'Question',
        name: 'What conditions should I include in my offer?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The three most common conditions are financing (to secure mortgage approval), home inspection (to identify structural or safety issues), and status certificate review (for condos). Your agent may recommend additional conditions depending on the property type and situation.',
        },
      },
      {
        '@type': 'Question',
        name: 'How long does it take to buy a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The search-to-closing process typically takes 3 to 6 months. Saving for a down payment can add 1 to 5 years of preparation. Once your offer is accepted, closing usually takes 30 to 90 days.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the first step to buying a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Start by checking your credit score and getting a mortgage pre-approval to understand how much you can borrow. Open an FHSA as early as possible to start the tax-advantaged savings clock, even if you are not ready to buy for several years.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I qualify for a mortgage if I am self-employed?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, but you typically need at least 2 years of self-employment history. Lenders may use a Business-for-Self (BFS) program and review your Notice of Assessment. A larger down payment or strong business financials can improve your approval odds.',
        },
      },
      {
        '@type': 'Question',
        name: 'What types of properties can first-time buyers purchase?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'First-time buyers can purchase detached houses, semi-detached homes, townhouses, condos, and in some cases duplexes or triplexes (if you live in one unit). Each property type has different down payment, insurance, and maintenance considerations.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need a real estate lawyer to buy a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, in most Canadian provinces a real estate lawyer is required to close a property purchase. They review the Agreement of Purchase and Sale, conduct title searches, register the mortgage, and handle the transfer of funds on closing day.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I handle a bidding war?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Set a firm maximum price before you bid and do not exceed it. Strengthen your offer with a pre-approval letter, a larger deposit, and flexible closing dates. Your agent can advise on escalation clauses and whether waiving conditions is appropriate for your situation.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much should I save beyond the down payment?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Plan to save an additional 1.5% to 4% of the purchase price for closing costs, plus 3 to 6 months of housing expenses as an emergency fund. Having this financial buffer reduces stress and protects you from unexpected costs after closing.',
        },
      },
    ],
  });
}

// --- HowTo (home page only) ---
if (type === 'home') {
  graph.push({
    '@type': 'HowTo',
    '@id': `${siteUrl}/#howto`,
    name: 'How to Buy Your First Home in Canada',
    description: 'A step-by-step guide for first-time home buyers in Canada, covering financial readiness, saving strategies, mortgages, government programs, finding a home, and the closing process.',
    totalTime: 'P6M',
    estimatedCost: {
      '@type': 'MonetaryAmount',
      currency: 'CAD',
      value: '25000',
    },
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Assess your readiness',
        text: 'Determine if you qualify as a first-time buyer, check your credit score (680+ is ideal), understand the mortgage stress test, and consider whether co-buying with a partner or family member makes sense.',
        url: `${siteUrl}/guide/1-are-you-ready/1-first-time-buyer/`,
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Start saving strategically',
        text: 'Open an FHSA ($8,000/year tax-deductible) and plan RRSP HBP withdrawals (up to $60,000 per person) to maximize your down payment. Combine both for up to $100,000 per person.',
        url: `${siteUrl}/guide/2-saving-smart/1-fhsa/`,
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Understand your mortgage options',
        text: 'Learn down payment rules (5% minimum), choose between fixed and variable rates, and get pre-approved for a mortgage. Self-employed buyers should prepare 2 years of tax documentation.',
        url: `${siteUrl}/guide/3-down-payments-mortgages/1-down-payment-rules/`,
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Claim government programs',
        text: 'Apply for all eligible federal, provincial, and territorial programs including HBTC ($1,500 credit), land transfer tax rebates, and location-specific incentives across all 10 provinces and 3 territories.',
        url: `${siteUrl}/guide/4-government-programs/1-federal-programs/`,
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'Build your team and find the right home',
        text: 'Assemble your team (real estate agent, mortgage broker, lawyer, inspector), search MLS listings, evaluate properties (resale, condo, freehold, or pre-construction/new builds), and attend viewings.',
        url: `${siteUrl}/guide/5-finding-a-home/1-working-with-realtor/`,
      },
      {
        '@type': 'HowToStep',
        position: 6,
        name: 'Make an offer',
        text: 'Submit an Agreement of Purchase and Sale with appropriate conditions (financing, inspection), negotiate terms, and secure the deal. Prepare for possible bidding wars with a clear maximum price.',
        url: `${siteUrl}/guide/6-making-an-offer/1-purchase-agreement/`,
      },
      {
        '@type': 'HowToStep',
        position: 7,
        name: 'Close the deal',
        text: 'Work with your lawyer on closing documents, arrange title insurance, complete the final walkthrough, and receive your keys. Budget 1.5% to 4% of the purchase price for closing costs.',
        url: `${siteUrl}/guide/7-closing-the-deal/1-closing-costs-overview/`,
      },
      {
        '@type': 'HowToStep',
        position: 8,
        name: 'Settle into homeownership',
        text: 'Build an emergency fund, set up property tax payments, arrange home insurance, and plan for ongoing maintenance and future mortgage renewals.',
        url: `${siteUrl}/guide/8-life-after-closing/1-emergency-fund/`,
      },
    ],
  });
}

// --- CollectionPage + SoftwareApplication (tools index) ---
if (type === 'tools') {
  graph.push({
    '@type': 'CollectionPage',
    '@id': `${siteUrl}/tools/#collection`,
    name: 'Home Buying Calculators & Tools',
    description: 'Free interactive calculators and tools for Canadian first-time home buyers — mortgage payments, affordability, closing costs, and more.',
    url: `${siteUrl}/tools/`,
    provider: { '@id': `${siteUrl}/#organization` },
    inLanguage: 'en-CA',
  });

  graph.push({
    '@type': 'SoftwareApplication',
    '@id': `${siteUrl}/tools/#software`,
    name: 'FirstHomeGuide.ca Home Buying Calculators',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CAD',
    },
    provider: { '@id': `${siteUrl}/#organization` },
    featureList: [
      'Mortgage Payment Calculator',
      'How Much Can I Afford Calculator',
      'Closing Cost Calculator',
      'Rent vs. Buy Comparison',
      'FHSA vs. RRSP/HBP Comparison',
      'Fixed vs. Variable Rate Comparison',
      'Timeline Planner',
      'City Comparison',
      'Document Checklist',
      'Province-Specific Program Finder',
      'Am I Ready? Assessment',
      'Cost of Waiting Calculator',
    ],
    url: `${siteUrl}/tools/`,
  });

  // BreadcrumbList for tools index
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Calculators & Tools' },
    ],
  });
}

// --- WebApplication (individual tool pages) ---
if (type === 'tool-page' && toolSlug) {
  const toolData: Record<string, { name: string; description: string }> = {
    'mortgage-calculator': {
      name: 'Canadian Mortgage Payment Calculator',
      description: 'Calculate monthly mortgage payments, CMHC insurance premiums, land transfer tax by province, and stress test qualification for Canadian home buyers.',
    },
    'affordability-calculator': {
      name: 'Home Affordability Calculator',
      description: 'Find out how much home you can afford based on income, debts, and down payment using Canadian GDS/TDS rules and stress test rates.',
    },
    'closing-cost-calculator': {
      name: 'Closing Cost Calculator for Canada',
      description: 'Estimate total closing costs including legal fees, land transfer tax, PST on CMHC insurance, and more — calculated by province.',
    },
    'comparison-tools': {
      name: 'Home Buying Comparison Tools',
      description: 'Compare Rent vs. Buy, FHSA vs. RRSP/HBP, and Fixed vs. Variable mortgage rates side by side for Canadian buyers.',
    },
    'timeline-planner': {
      name: 'Home Buying Timeline Planner',
      description: 'Plan your home purchase timeline from saving to closing with realistic milestones for Canadian first-time buyers.',
    },
    'city-comparison': {
      name: 'Canadian City Comparison Tool',
      description: 'Compare housing costs, affordability, and market data across Canadian cities to find the best fit.',
    },
    'document-checklist': {
      name: 'Mortgage Document Checklist',
      description: 'Interactive checklist of all documents needed for your Canadian mortgage application — employment, income, identity, and property docs.',
    },
    'province-selector': {
      name: 'Provincial Home Buyer Program Finder',
      description: 'Find first-time home buyer programs and incentives available in your province or territory across Canada.',
    },
    'readiness-assessment': {
      name: 'Am I Ready to Buy? Assessment',
      description: 'Evaluate your financial readiness to purchase your first home in Canada with this interactive assessment tool.',
    },
    'cost-of-waiting': {
      name: 'Cost of Waiting Calculator',
      description: 'See how much waiting to buy could cost you as Canadian home prices and mortgage rates change over time.',
    },
  };

  const toolNames: Record<string, string> = {
    'mortgage-calculator': 'Mortgage Calculator',
    'affordability-calculator': 'Affordability Calculator',
    'closing-cost-calculator': 'Closing Cost Calculator',
    'comparison-tools': 'Comparison Tools',
    'timeline-planner': 'Timeline Planner',
    'city-comparison': 'City Comparison',
    'document-checklist': 'Document Checklist',
    'province-selector': 'Province Selector',
    'readiness-assessment': 'Readiness Assessment',
    'cost-of-waiting': 'Cost of Waiting',
  };

  const tool = toolData[toolSlug];
  if (tool) {
    graph.push({
      '@type': 'WebApplication',
      '@id': `${siteUrl}/tools/${toolSlug}/#app`,
      name: tool.name,
      description: tool.description,
      url: `${siteUrl}/tools/${toolSlug}/`,
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Web',
      browserRequirements: 'Requires JavaScript',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'CAD',
      },
      provider: { '@id': `${siteUrl}/#organization` },
      inLanguage: 'en-CA',
    });
  }

  // BreadcrumbList for tool pages
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Calculators & Tools', item: `${siteUrl}/tools/` },
      { '@type': 'ListItem', position: 3, name: toolNames[toolSlug] || title || toolSlug },
    ],
  });
}

// --- AboutPage ---
if (type === 'about') {
  graph.push({
    '@type': 'AboutPage',
    '@id': `${siteUrl}/about/#page`,
    name: 'About FirstHomeGuide.ca',
    description: 'Learn about FirstHomeGuide.ca — a free, independent education platform helping Canadians navigate buying their first home, powered by LendCity mortgage experts.',
    url: `${siteUrl}/about/`,
    inLanguage: 'en-CA',
    about: { '@id': `${siteUrl}/#organization` },
  });

  // BreadcrumbList for about page
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'About' },
    ],
  });
}

const schemaOutput = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaOutput)} />
