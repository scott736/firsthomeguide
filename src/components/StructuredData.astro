---
/**
 * Structured Data (JSON-LD) component for SEO and AI citability.
 * Renders Course, WebSite, Organization, FAQPage, and HowTo schemas.
 */

interface Props {
  type?: 'home' | 'guide' | 'module';
  title?: string;
  description?: string;
  moduleNumber?: number;
}

const { type = 'home', title, description, moduleNumber } = Astro.props;
const siteUrl = 'https://firsthomeguide.ca';

// Organization schema (always included)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'FirstHomeGuide.ca',
  url: siteUrl,
  logo: `${siteUrl}/layout/logo-light.svg`,
  description: 'Free, independent education resource for first-time home buyers in Canada.',
  sameAs: [],
};

// WebSite schema (home page)
const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'FirstHomeGuide.ca',
  url: siteUrl,
  description: 'The most comprehensive free resource for first-time home buyers in Canada.',
  publisher: {
    '@type': 'Organization',
    name: 'FirstHomeGuide.ca',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/guide/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

// Course schema (the guide as a whole)
const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'First-Time Home Buyer Guide for Canada',
  description: 'A free, comprehensive 8-module course covering everything Canadian first-time home buyers need to know — from financial readiness to closing day and beyond.',
  provider: {
    '@type': 'Organization',
    name: 'FirstHomeGuide.ca',
    url: siteUrl,
  },
  url: `${siteUrl}/guide/`,
  educationalLevel: 'Beginner',
  isAccessibleForFree: true,
  inLanguage: 'en-CA',
  numberOfCredits: 0,
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT2H',
  },
  syllabusSections: [
    { '@type': 'Syllabus', name: 'Module 1: Are You Ready to Buy?', position: 1, url: `${siteUrl}/guide/1-are-you-ready/1-first-time-buyer/` },
    { '@type': 'Syllabus', name: 'Module 2: Saving Smart — FHSA, RRSP HBP & More', position: 2, url: `${siteUrl}/guide/2-saving-smart/1-fhsa/` },
    { '@type': 'Syllabus', name: 'Module 3: Down Payments & Mortgage Basics', position: 3, url: `${siteUrl}/guide/3-down-payments-mortgages/1-down-payment-rules/` },
    { '@type': 'Syllabus', name: 'Module 4: Government Programs by Province', position: 4, url: `${siteUrl}/guide/4-government-programs/1-federal-programs/` },
    { '@type': 'Syllabus', name: 'Module 5: Finding a Home', position: 5, url: `${siteUrl}/guide/5-finding-a-home/1-working-with-realtor/` },
    { '@type': 'Syllabus', name: 'Module 6: Making an Offer', position: 6, url: `${siteUrl}/guide/6-making-an-offer/1-purchase-agreement/` },
    { '@type': 'Syllabus', name: 'Module 7: Closing the Deal', position: 7, url: `${siteUrl}/guide/7-closing-the-deal/1-closing-costs-overview/` },
    { '@type': 'Syllabus', name: 'Module 8: Life After Closing', position: 8, url: `${siteUrl}/guide/8-life-after-closing/1-emergency-fund/` },
  ],
};

// FAQPage schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much do I need for a down payment in Canada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The minimum down payment in Canada is 5% on the first $500,000 of the purchase price, 10% on the portion between $500,000 and $999,999, and 20% on homes priced at $1 million or more.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the First Home Savings Account (FHSA)?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The FHSA is a registered savings account that lets first-time home buyers save up to $40,000 ($8,000 per year) with tax-deductible contributions and tax-free withdrawals when used to purchase a qualifying first home.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much can I withdraw from my RRSP to buy a home?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Through the RRSP Home Buyers\' Plan (HBP), you can withdraw up to $60,000 per person to buy your first home. Couples can withdraw up to $120,000 combined. The withdrawal must be repaid to your RRSP over 15 years.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the mortgage stress test in Canada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The mortgage stress test requires all federally regulated lenders to qualify borrowers at the higher of their contract rate plus 2% or the Bank of Canada\'s qualifying rate (currently 5.25%). This ensures borrowers can handle potential interest rate increases.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need mortgage insurance in Canada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, mortgage insurance (from CMHC, Sagen, or Canada Guaranty) is required if your down payment is less than 20% of the purchase price. Premiums range from 2.4% to 4.0% of the mortgage amount, depending on your down payment percentage.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the typical closing costs when buying a home in Canada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Closing costs in Canada typically range from 1.5% to 4% of the purchase price. Major costs include land transfer tax (varies by province), legal fees ($1,500–$2,500), title insurance ($300–$500), home inspection ($400–$600), and property tax/utility adjustments.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the Home Buyers\' Tax Credit (HBTC)?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The HBTC is a federal non-refundable tax credit of $1,500 (calculated as $10,000 × 15%) available to first-time home buyers. You claim it on line 31270 of your income tax return for the year you purchased your home.',
      },
    },
  ],
};

// HowTo schema (the home buying process)
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Buy Your First Home in Canada',
  description: 'A step-by-step guide for first-time home buyers in Canada, covering financial readiness, saving strategies, mortgages, government programs, and the closing process.',
  totalTime: 'P6M',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'CAD',
    value: '25000',
  },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Assess your readiness',
      text: 'Determine if you qualify as a first-time buyer, check your credit score (680+ is ideal), and understand the mortgage stress test.',
      url: `${siteUrl}/guide/1-are-you-ready/1-first-time-buyer/`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Start saving strategically',
      text: 'Open an FHSA ($8,000/year tax-deductible) and plan RRSP HBP withdrawals (up to $60,000 per person) to maximize your down payment.',
      url: `${siteUrl}/guide/2-saving-smart/1-fhsa/`,
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Understand your mortgage options',
      text: 'Learn down payment rules (5% minimum), choose between fixed and variable rates, and get pre-approved for a mortgage.',
      url: `${siteUrl}/guide/3-down-payments-mortgages/1-down-payment-rules/`,
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Claim government programs',
      text: 'Apply for all eligible federal and provincial programs including HBTC ($1,500 credit), land transfer tax rebates, and province-specific incentives.',
      url: `${siteUrl}/guide/4-government-programs/1-federal-programs/`,
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Find the right home',
      text: 'Hire a buyer\'s agent, search MLS listings, evaluate properties (condo vs. freehold), and attend viewings.',
      url: `${siteUrl}/guide/5-finding-a-home/1-working-with-realtor/`,
    },
    {
      '@type': 'HowToStep',
      position: 6,
      name: 'Make an offer',
      text: 'Submit an Agreement of Purchase and Sale with appropriate conditions (financing, inspection), negotiate terms, and secure the deal.',
      url: `${siteUrl}/guide/6-making-an-offer/1-purchase-agreement/`,
    },
    {
      '@type': 'HowToStep',
      position: 7,
      name: 'Close the deal',
      text: 'Work with your lawyer on closing documents, arrange title insurance, complete the final walkthrough, and receive your keys.',
      url: `${siteUrl}/guide/7-closing-the-deal/1-closing-costs-overview/`,
    },
    {
      '@type': 'HowToStep',
      position: 8,
      name: 'Settle into homeownership',
      text: 'Build an emergency fund, set up property tax payments, arrange home insurance, and plan for ongoing maintenance.',
      url: `${siteUrl}/guide/8-life-after-closing/1-emergency-fund/`,
    },
  ],
};

// Choose schemas based on page type
const schemas = [];
schemas.push(organizationSchema);

if (type === 'home') {
  schemas.push(webSiteSchema);
  schemas.push(courseSchema);
  schemas.push(faqSchema);
  schemas.push(howToSchema);
} else if (type === 'guide') {
  schemas.push(courseSchema);
}
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
