---
/**
 * Custom Starlight Head component override.
 * Adds structured data (JSON-LD) using @graph pattern, OG/Twitter meta tags,
 * breadcrumb schema, entity linking, and AEO/GEO signals for guide pages.
 */
import Default from '@astrojs/starlight/components/Head.astro';

import { LENDCITY } from '@/lib/lendcity';

const siteUrl = 'https://firsthomeguide.ca';
const telephoneE164 = `+${LENDCITY.phone.replace(/\D/g, '')}`;

// Access page data via Astro.locals.starlightRoute (Starlight's current API)
const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const description = route.entry.data.description || '';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;

// Use WebP for all OG/Twitter images — SVGs are not rendered by most social crawlers
const ogImage = new URL('/images/og-image.webp', siteUrl).href;
const twitterImage = ogImage;
const ogImageAlt = "FirstHomeGuide.ca \u2014 Canada's Free First-Time Home Buyer Guide";

// Build date for dateModified (set at build time)
const dateModified = new Date().toISOString().split('T')[0];

// --- Breadcrumb generation ---
const pathSegments = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/');

const moduleNames: Record<string, string> = {
  '1-are-you-ready': 'Are You Ready?',
  '2-saving-smart': 'Saving Smart',
  '3-down-payments-mortgages': 'Down Payments & Mortgages',
  '4-government-programs': 'Government Programs',
  '5-finding-a-home': 'Finding a Home',
  '6-making-an-offer': 'Making an Offer',
  '7-closing-the-deal': 'Closing the Deal',
  '8-life-after-closing': 'Life After Closing',
};

const breadcrumbItems: Array<{ name: string; item?: string }> = [
  { name: 'Home', item: `${siteUrl}/` },
  { name: 'Guide', item: `${siteUrl}/guide/welcome/` },
];

if (pathSegments.length >= 3 && moduleNames[pathSegments[1]]) {
  const moduleSlug = pathSegments[1];
  const moduleName = moduleNames[moduleSlug];
  breadcrumbItems.push({
    name: moduleName,
    item: `${siteUrl}/guide/${moduleSlug}/`,
  });
}

breadcrumbItems.push({ name: title });

const breadcrumbListItems = breadcrumbItems.map((crumb, index) => {
  const item: Record<string, unknown> = {
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.name,
  };
  if (crumb.item) {
    item.item = crumb.item;
  }
  return item;
});

// --- Detect special page types ---
const isFaqPage = Astro.url.pathname.replace(/\/$/, '') === '/guide/faq';
const isGlossaryPage = Astro.url.pathname.replace(/\/$/, '') === '/guide/glossary';

// Determine module slug from path for entity/citation mapping
const moduleSlug = pathSegments.length >= 2 ? pathSegments[1] : '';

// --- Entity mapping: article topics → Wikipedia/Wikidata about links ---
// Helps AI systems understand what concepts each article covers
const topicEntities: Record<string, Array<{ '@type': string; name: string; sameAs: string }>> = {
  '1-are-you-ready': [
    { '@type': 'Thing', name: 'First-time home buying', sameAs: 'https://en.wikipedia.org/wiki/First-time_home_buyer' },
    { '@type': 'Thing', name: 'Mortgage loan', sameAs: 'https://en.wikipedia.org/wiki/Mortgage_loan' },
  ],
  '2-saving-smart': [
    { '@type': 'Thing', name: 'First Home Savings Account', sameAs: 'https://en.wikipedia.org/wiki/First_Home_Savings_Account' },
    { '@type': 'Thing', name: 'Registered Retirement Savings Plan', sameAs: 'https://en.wikipedia.org/wiki/Registered_retirement_savings_plan' },
    { '@type': 'Thing', name: 'Tax-free savings account', sameAs: 'https://en.wikipedia.org/wiki/Tax-free_savings_account_(Canada)' },
  ],
  '3-down-payments-mortgages': [
    { '@type': 'Thing', name: 'Down payment', sameAs: 'https://en.wikipedia.org/wiki/Down_payment' },
    { '@type': 'Thing', name: 'Canada Mortgage and Housing Corporation', sameAs: 'https://en.wikipedia.org/wiki/Canada_Mortgage_and_Housing_Corporation' },
    { '@type': 'Thing', name: 'Mortgage insurance', sameAs: 'https://en.wikipedia.org/wiki/Mortgage_insurance' },
  ],
  '4-government-programs': [
    { '@type': 'GovernmentOrganization', name: 'Government of Canada', sameAs: 'https://en.wikipedia.org/wiki/Government_of_Canada' },
    { '@type': 'Thing', name: 'Land transfer tax', sameAs: 'https://en.wikipedia.org/wiki/Land_transfer_tax' },
  ],
  '5-finding-a-home': [
    { '@type': 'Thing', name: 'Real estate agent', sameAs: 'https://en.wikipedia.org/wiki/Real_estate_agent' },
    { '@type': 'Thing', name: 'Multiple listing service', sameAs: 'https://en.wikipedia.org/wiki/Multiple_listing_service' },
  ],
  '6-making-an-offer': [
    { '@type': 'Thing', name: 'Purchase agreement', sameAs: 'https://en.wikipedia.org/wiki/Purchase_agreement' },
    { '@type': 'Thing', name: 'Home inspection', sameAs: 'https://en.wikipedia.org/wiki/Home_inspection' },
  ],
  '7-closing-the-deal': [
    { '@type': 'Thing', name: 'Title insurance', sameAs: 'https://en.wikipedia.org/wiki/Title_insurance' },
    { '@type': 'Thing', name: 'Closing costs', sameAs: 'https://en.wikipedia.org/wiki/Closing_costs' },
  ],
  '8-life-after-closing': [
    { '@type': 'Thing', name: 'Property tax', sameAs: 'https://en.wikipedia.org/wiki/Property_tax' },
    { '@type': 'Thing', name: 'Home insurance', sameAs: 'https://en.wikipedia.org/wiki/Home_insurance' },
  ],
};

// --- Citation sources for authoritative government references ---
// Helps AI systems verify facts and increases citation likelihood
const citationSources: Record<string, Array<{ '@type': string; name: string; url: string }>> = {
  '2-saving-smart': [
    { '@type': 'WebPage', name: 'CRA \u2014 First Home Savings Account', url: 'https://www.canada.ca/en/revenue-agency/services/tax/individuals/topics/first-home-savings-account.html' },
    { '@type': 'WebPage', name: 'CRA \u2014 Home Buyers\' Plan', url: 'https://www.canada.ca/en/revenue-agency/services/tax/individuals/topics/rrsps-related-plans/what-home-buyers-plan.html' },
  ],
  '3-down-payments-mortgages': [
    { '@type': 'WebPage', name: 'CMHC \u2014 Mortgage Loan Insurance', url: 'https://www.cmhc-schl.gc.ca/consumers/home-buying/mortgage-loan-insurance-for-consumers' },
    { '@type': 'WebPage', name: 'OSFI \u2014 Residential Mortgage Underwriting', url: 'https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/residential-mortgage-underwriting-practices-procedures' },
  ],
  '4-government-programs': [
    { '@type': 'WebPage', name: 'CRA \u2014 Home Buyers\' Tax Credit', url: 'https://www.canada.ca/en/revenue-agency/services/tax/individuals/topics/about-your-tax-return/tax-return/completing-a-tax-return/deductions-credits-expenses/line-31270-home-buyers-amount.html' },
    { '@type': 'WebPage', name: 'CRA \u2014 GST/HST New Housing Rebate', url: 'https://www.canada.ca/en/revenue-agency/services/forms-publications/publications/rc4028.html' },
  ],
};

// --- Build @graph array ---
const graph: Record<string, unknown>[] = [];

// Organization — enhanced with knowsAbout, parentOrganization, and expanded sameAs
graph.push({
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'FirstHomeGuide.ca',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    '@id': `${siteUrl}/#logo`,
    url: `${siteUrl}/layout/logo-light.svg`,
    contentUrl: `${siteUrl}/layout/logo-light.svg`,
    caption: 'FirstHomeGuide.ca',
  },
  image: { '@id': `${siteUrl}/#logo` },
  description: 'Free, independent education resource for first-time home buyers in Canada.',
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
    sameAs: 'https://en.wikipedia.org/wiki/Canada',
  },
  knowsAbout: [
    'First-time home buying in Canada',
    'First Home Savings Account (FHSA)',
    'RRSP Home Buyers\' Plan',
    'CMHC mortgage insurance',
    'Canadian mortgage rates',
    'Provincial home buyer programs',
    'Closing costs in Canada',
    'Land transfer tax',
    'Mortgage stress test',
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: LENDCITY.streetAddress,
    addressLocality: LENDCITY.city,
    addressRegion: LENDCITY.provinceCode,
    postalCode: LENDCITY.postalCode,
    addressCountry: LENDCITY.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: telephoneE164,
    contactType: 'customer service',
    areaServed: 'CA',
    availableLanguage: 'English',
  },
  sameAs: [
    'https://twitter.com/FirstHomeGuideCA',
    'https://www.lendcity.ca',
  ],
  parentOrganization: {
    '@type': 'Organization',
    name: 'LendCity',
    url: 'https://www.lendcity.ca',
    description: 'Licensed Mortgage Professionals under Mortgage Architects',
  },
});

// Article — enhanced with entity linking, citations, educational metadata, and AEO signals
const articleSchema: Record<string, unknown> = {
  '@type': 'Article',
  '@id': canonicalURL,
  headline: title,
  description: description,
  author: { '@id': `${siteUrl}/#organization` },
  publisher: { '@id': `${siteUrl}/#organization` },
  datePublished: '2025-01-15',
  dateModified: dateModified,
  mainEntityOfPage: canonicalURL,
  isPartOf: {
    '@type': 'Course',
    '@id': `${siteUrl}/guide/#course`,
    name: "The Complete First-Time Home Buyer's Guide \u2014 Canada",
    provider: { '@id': `${siteUrl}/#organization` },
  },
  inLanguage: 'en-CA',
  image: ogImage,
  isAccessibleForFree: true,
  educationalLevel: 'Beginner',
  learningResourceType: 'guide',
  audience: {
    '@type': 'EducationalAudience',
    educationalRole: 'student',
    audienceType: 'First-time home buyers in Canada',
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'h2', '[role="note"]', '.sl-markdown-content > p:first-of-type', '[data-aeo-answer]'],
  },
  potentialAction: {
    '@type': 'ReadAction',
    target: canonicalURL,
  },
};

// Attach entity about links when the module has mapped topics
if (topicEntities[moduleSlug]) {
  articleSchema.about = topicEntities[moduleSlug];
}

// Attach citation links to authoritative government sources
if (citationSources[moduleSlug]) {
  articleSchema.citation = citationSources[moduleSlug];
}

graph.push(articleSchema);

// FAQPage schema for the FAQ page
if (isFaqPage) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${canonicalURL}#faq`,
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much do I need for a down payment in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The minimum down payment in Canada is 5% on the first $500,000 of the purchase price, 10% on the portion between $500,000 and $1,499,999, and 20% on homes priced at $1,500,000 or more. If your down payment is less than 20%, you will also pay CMHC mortgage insurance (2.8% to 4.0% of the mortgage amount).',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the First Home Savings Account (FHSA)?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The FHSA is a registered account with a double tax advantage: contributions are tax-deductible (like an RRSP) and qualifying withdrawals for a home purchase are completely tax-free (like a TFSA). You can contribute up to $8,000 per year with a lifetime maximum of $40,000. If you do not buy, you can roll the balance into your RRSP penalty-free.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between the FHSA and the RRSP Home Buyers\' Plan?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The FHSA provides tax-deductible contributions and tax-free withdrawals with no repayment required. The RRSP Home Buyers\' Plan (HBP) lets you withdraw up to $60,000 tax-free but you must repay the full amount over 15 years. You can use both together for up to $100,000 per person ($200,000 as a couple).',
        },
      },
      {
        '@type': 'Question',
        name: 'What credit score do I need to buy a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Most Canadian lenders require a minimum credit score of 680 for the best rates. Some lenders approve mortgages with scores as low as 600 but at higher rates. A score of 760 or above qualifies you for the most competitive rates available.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the mortgage stress test in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The stress test requires all federally regulated lenders to qualify borrowers at the higher of their contract rate plus 2% or the Bank of Canada\'s benchmark qualifying rate (currently 5.25%). It reduces the maximum mortgage you qualify for by roughly 20% compared to qualifying at your actual rate.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much are closing costs in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Budget 3% to 5% of the purchase price for closing costs. On a $500,000 home, that means $15,000 to $25,000. Major costs include land transfer tax (varies by province), legal fees ($1,500 to $2,500), title insurance ($250 to $500), home appraisal ($300 to $500), and property tax adjustments.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is CMHC insurance and do I need it?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'CMHC insurance (mortgage default insurance) is required when your down payment is less than 20%. The premium is 2.8% to 4.0% of the mortgage amount and is typically added to your mortgage balance. On a $500,000 home with 5% down, the premium is approximately $19,000.',
        },
      },
      {
        '@type': 'Question',
        name: 'Should I get a fixed or variable rate mortgage?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Fixed-rate mortgages give payment certainty for the entire term (typically 5 years). Variable-rate mortgages are historically cheaper but fluctuate with the Bank of Canada\'s policy rate. Most first-time buyers choose a 5-year fixed term for predictability.',
        },
      },
      {
        '@type': 'Question',
        name: 'What government programs are available for first-time home buyers in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Federal programs include the FHSA (up to $40,000 tax-advantaged savings), RRSP Home Buyers\' Plan (up to $60,000 tax-free withdrawal), and Home Buyers\' Tax Credit ($1,500). Each province has additional programs \u2014 Ontario offers land transfer tax rebates up to $4,000, BC offers full property transfer tax exemption on homes up to $500,000, and Alberta has no land transfer tax.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need a real estate lawyer to buy a home in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. In most Canadian provinces, a real estate lawyer is required to complete a property purchase. They review the Agreement of Purchase and Sale, conduct title searches, register the mortgage and title transfer, and handle the transfer of funds on closing day. Legal fees typically run $1,500 to $2,500.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is land transfer tax in Canada?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Land transfer tax is a provincial tax paid when you purchase a property, calculated as a percentage of the purchase price. It is usually the single largest closing cost. Rates vary: Alberta and Saskatchewan charge only modest registration fees, while Ontario charges a tiered tax. Most provinces offer first-time buyer rebates.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I know if I am ready to buy a home?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'You are likely ready if you have: a stable income that supports mortgage payments plus carrying costs, a credit score of at least 680, enough savings for a down payment and 3-5% closing costs, an emergency fund of 3-6 months of expenses, and manageable existing debt.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is a home inspection and do I need one?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A home inspection is a professional examination of a property\'s structure, systems, and components. It costs $400 to $600 and takes two to four hours. A single major finding can cost $10,000 to $50,000+ to fix, making the inspection one of the most important steps in the buying process.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I buy a home in Canada if I am self-employed?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, but you typically need at least 2 years of self-employment history with tax returns, Notices of Assessment, and financial statements. Some lenders offer stated income programs for self-employed borrowers with strong credit. A mortgage broker is especially valuable for finding flexible lenders.',
        },
      },
      {
        '@type': 'Question',
        name: 'What happens on closing day when buying a home?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'On closing day, your lawyer transfers purchase funds to the seller\'s lawyer. The seller\'s lawyer confirms receipt, releases the keys, and registers the title transfer. You will have signed all documents a few days before. Once confirmed, your agent or lawyer lets you know the keys are available for pickup.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much should I budget for home maintenance?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Budget 1% of your home\'s value per year for maintenance. On a $500,000 home, that is $5,000 per year. For older homes, budget 1.5% to 2%. For condos, condo fees cover common element maintenance but you are responsible for everything inside your unit.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is title insurance?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Title insurance is a one-time policy ($250 to $500) that protects against problems with your property\'s legal title \u2014 including fraud, forgery, unknown liens, and survey errors. Lender\'s title insurance is required by most lenders; owner\'s title insurance is optional but strongly recommended.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between a condo and a freehold?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A freehold means you own the building and the land. You handle all maintenance but have full control. A condominium means you own your unit, while common elements are shared. Monthly condo fees ($300 to $800+) cover shared maintenance. Condos are often more affordable as an entry point.',
        },
      },
      {
        '@type': 'Question',
        name: 'Should I use a mortgage broker or go to my bank?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A mortgage broker has access to dozens of lenders and can often find rates 0.1% to 0.5% lower than your bank. Brokers are typically paid by the lender. The best approach is to get quotes from both your bank and a broker, then compare. Even a 0.2% difference can save $5,000 to $10,000 over a five-year term.',
        },
      },
      {
        '@type': 'Question',
        name: 'When should I start saving for a home?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'As soon as you think homeownership might be in your future. Open an FHSA immediately (even a $100 contribution starts your room clock), set up automatic contributions, and aim to save at least 10-15% of your income. Starting $500/month five years early yields approximately $33,000 to $38,000.',
        },
      },
    ],
  });
}

// DefinedTermSet schema for the glossary page
if (isGlossaryPage) {
  graph.push({
    '@type': 'DefinedTermSet',
    '@id': `${canonicalURL}#glossary`,
    name: 'Canadian Home Buying Glossary',
    description: 'Definitions of key terms used in Canadian real estate and the first-time home buying process.',
    url: canonicalURL,
    inLanguage: 'en-CA',
    provider: { '@id': `${siteUrl}/#organization` },
    about: {
      '@type': 'Thing',
      name: 'Real estate terminology in Canada',
      sameAs: 'https://en.wikipedia.org/wiki/Real_estate',
    },
  });
}

// BreadcrumbList
graph.push({
  '@type': 'BreadcrumbList',
  '@id': `${canonicalURL}#breadcrumb`,
  itemListElement: breadcrumbListItems,
});

const schemaOutput = {
  '@context': 'https://schema.org',
  '@graph': graph,
};

// --- OG meta tag values ---
const ogTitle = `${title} \u2014 FirstHomeGuide.ca`;
---

<!-- Render Starlight's default Head first (handles base meta, fonts, etc.) -->
<Default {...Astro.props}><slot /></Default>

<!-- LLMs discovery links -->
<link rel="alternate" type="text/plain" title="LLMs" href="/llms.txt" />
<link rel="alternate" type="text/plain" title="LLMs Full" href="/llms-full.txt" />

<!-- Structured Data (@graph pattern) -->
<script type="application/ld+json" set:html={JSON.stringify(schemaOutput)} />

<!-- Open Graph meta tags -->
<meta property="og:type" content="article" />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="FirstHomeGuide.ca" />
<meta property="og:locale" content="en_CA" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:type" content="image/webp" />
<meta property="article:published_time" content="2025-01-15T00:00:00Z" />
<meta property="article:modified_time" content={`${dateModified}T00:00:00Z`} />

<!-- Twitter Card meta tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={twitterImage} />
<meta name="twitter:creator" content="@FirstHomeGuideCA" />
<meta name="twitter:site" content="@FirstHomeGuideCA" />
