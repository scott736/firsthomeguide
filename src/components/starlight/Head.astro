---
/**
 * Custom Starlight Head component override.
 * Adds structured data (JSON-LD) using @graph pattern, OG/Twitter meta tags,
 * and breadcrumb schema for guide pages, improving SEO and social sharing.
 */
import Default from '@astrojs/starlight/components/Head.astro';

const siteUrl = 'https://firsthomeguide.ca';

// Access page data via Astro.locals.starlightRoute (Starlight's current API)
const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const description = route.entry.data.description || '';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;

// Use WebP for all OG/Twitter images — SVGs are not rendered by most social crawlers
const ogImage = new URL('/images/og-image.webp', siteUrl).href;
const twitterImage = ogImage;
const ogImageAlt = "FirstHomeGuide.ca \u2014 Canada's Free First-Time Home Buyer Guide";

// Build date for dateModified (set at build time)
const dateModified = new Date().toISOString().split('T')[0];

// --- Breadcrumb generation ---
const pathSegments = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/');

const moduleNames: Record<string, string> = {
  '1-are-you-ready': 'Are You Ready?',
  '2-saving-smart': 'Saving Smart',
  '3-down-payments-mortgages': 'Down Payments & Mortgages',
  '4-government-programs': 'Government Programs',
  '5-finding-a-home': 'Finding a Home',
  '6-making-an-offer': 'Making an Offer',
  '7-closing-the-deal': 'Closing the Deal',
  '8-life-after-closing': 'Life After Closing',
};

const breadcrumbItems: Array<{ name: string; item?: string }> = [
  { name: 'Home', item: `${siteUrl}/` },
  { name: 'Guide', item: `${siteUrl}/guide/welcome/` },
];

if (pathSegments.length >= 3 && moduleNames[pathSegments[1]]) {
  const moduleSlug = pathSegments[1];
  const moduleName = moduleNames[moduleSlug];
  breadcrumbItems.push({
    name: moduleName,
    item: `${siteUrl}/guide/${moduleSlug}/`,
  });
}

breadcrumbItems.push({ name: title });

const breadcrumbListItems = breadcrumbItems.map((crumb, index) => {
  const item: Record<string, unknown> = {
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.name,
  };
  if (crumb.item) {
    item.item = crumb.item;
  }
  return item;
});

// --- Build @graph array ---
const graph: Record<string, unknown>[] = [];

// Organization
graph.push({
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'FirstHomeGuide.ca',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    '@id': `${siteUrl}/#logo`,
    url: `${siteUrl}/layout/logo-light.svg`,
    contentUrl: `${siteUrl}/layout/logo-light.svg`,
    caption: 'FirstHomeGuide.ca',
  },
  image: { '@id': `${siteUrl}/#logo` },
  description: 'Free, independent education resource for first-time home buyers in Canada.',
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
    sameAs: 'https://en.wikipedia.org/wiki/Canada',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-519-960-0370',
    contactType: 'customer service',
    areaServed: 'CA',
    availableLanguage: 'English',
  },
  sameAs: ['https://twitter.com/FirstHomeGuideCA'],
});

// Article
graph.push({
  '@type': 'Article',
  '@id': canonicalURL,
  headline: title,
  description: description,
  author: { '@id': `${siteUrl}/#organization` },
  publisher: { '@id': `${siteUrl}/#organization` },
  datePublished: '2025-01-15',
  dateModified: dateModified,
  mainEntityOfPage: canonicalURL,
  isPartOf: {
    '@type': 'Course',
    '@id': `${siteUrl}/guide/#course`,
    name: "The Complete First-Time Home Buyer's Guide \u2014 Canada",
    provider: { '@id': `${siteUrl}/#organization` },
  },
  inLanguage: 'en-CA',
  image: ogImage,
});

// BreadcrumbList
graph.push({
  '@type': 'BreadcrumbList',
  '@id': `${canonicalURL}#breadcrumb`,
  itemListElement: breadcrumbListItems,
});

const schemaOutput = {
  '@context': 'https://schema.org',
  '@graph': graph,
};

// --- OG meta tag values ---
const ogTitle = `${title} \u2014 FirstHomeGuide.ca`;
---

<!-- Render Starlight's default Head first (handles base meta, fonts, etc.) -->
<Default {...Astro.props}><slot /></Default>

<!-- Structured Data (@graph pattern) -->
<script type="application/ld+json" set:html={JSON.stringify(schemaOutput)} />

<!-- Open Graph meta tags -->
<meta property="og:type" content="article" />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="FirstHomeGuide.ca" />
<meta property="og:locale" content="en_CA" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:type" content="image/webp" />
<meta property="article:published_time" content="2025-01-15T00:00:00Z" />
<meta property="article:modified_time" content={`${dateModified}T00:00:00Z`} />

<!-- Twitter Card meta tags (JPEG fallback for compatibility) -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={twitterImage} />
<meta name="twitter:creator" content="@FirstHomeGuideCA" />
<meta name="twitter:site" content="@FirstHomeGuideCA" />
