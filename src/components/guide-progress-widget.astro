---
---

<div id="guide-progress" class="guide-progress">
  <button
    id="guide-progress-toggle"
    class="guide-progress-header"
    aria-expanded="false"
    aria-controls="guide-progress-details"
  >
    <div class="guide-progress-summary">
      <span class="guide-progress-text">Loading...</span>
      <svg class="guide-progress-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>
    <div class="guide-progress-bar-container">
      <div class="guide-progress-bar-fill" style="width: 0%"></div>
    </div>
  </button>
  <div id="guide-progress-details" class="guide-progress-details" hidden>
    <div id="guide-progress-modules"></div>
    <button id="guide-progress-reset" class="guide-progress-reset">
      Reset progress
    </button>
  </div>
</div>

<style>
  .guide-progress {
    font-size: 0.75rem;
    line-height: 1.3;
  }
  .guide-progress-header {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
  }
  .guide-progress-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .guide-progress-text {
    font-weight: 500;
    opacity: 0.85;
  }
  .guide-progress-chevron {
    transition: transform 0.2s;
    opacity: 0.5;
    flex-shrink: 0;
  }
  .guide-progress-header[aria-expanded="true"] .guide-progress-chevron {
    transform: rotate(180deg);
  }
  .guide-progress-bar-container {
    margin-top: 0.25rem;
    height: 3px;
    border-radius: 2px;
    background: var(--sl-color-gray-6, var(--muted, rgba(128,128,128,0.15)));
    overflow: hidden;
  }
  .guide-progress-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--sl-color-accent, var(--chart-1, #7c3aed));
    transition: width 0.3s ease;
  }
  .guide-progress-details {
    margin-top: 0.5rem;
    padding-top: 0.375rem;
    border-top: 1px solid var(--sl-color-gray-6, var(--border, rgba(128,128,128,0.2)));
    max-height: 60vh;
    overflow-y: auto;
  }
  .guide-progress-module {
    margin-bottom: 0.25rem;
  }
  .guide-progress-module-header {
    font-size: 0.6875rem;
    font-weight: 600;
    opacity: 0.55;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.25rem 0 0.0625rem;
  }
  .guide-progress-module-header a {
    color: inherit;
    text-decoration: none;
  }
  .guide-progress-module-header a:hover {
    opacity: 1;
    text-decoration: underline;
  }
  .guide-progress-page-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.25rem;
    margin: 0 -0.25rem;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: inherit;
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.12s;
    opacity: 0.5;
  }
  .guide-progress-page-link:hover {
    background: var(--sl-color-gray-6, rgba(128,128,128,0.08));
    opacity: 0.8;
    text-decoration: none;
  }
  .guide-progress-page-link.visited {
    opacity: 0.85;
  }
  .guide-progress-page-link.active {
    opacity: 1;
    background: var(--sl-color-accent-low, rgba(124, 58, 237, 0.08));
    font-weight: 500;
  }
  .guide-progress-status {
    flex-shrink: 0;
    width: 1em;
    text-align: center;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1;
  }
  .guide-progress-status.done {
    color: var(--sl-color-accent, var(--chart-1, #7c3aed));
  }
  .guide-progress-status.not-done {
    opacity: 0.3;
  }
  .guide-progress-reset {
    display: block;
    margin-top: 0.5rem;
    padding: 0.1875rem 0.375rem;
    font-size: 0.625rem;
    background: none;
    border: 1px solid var(--sl-color-gray-5, var(--border, rgba(128,128,128,0.2)));
    border-radius: 3px;
    color: inherit;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .guide-progress-reset:hover {
    opacity: 1;
  }
</style>

<script>
  const STORAGE_KEY = 'fhg-guide-progress';

  const GUIDE_MODULES = [
    {
      name: 'Welcome',
      pages: [
        { path: '/guide/welcome/', label: 'Welcome' },
      ],
    },
    {
      name: 'Module 1: Are You Ready?',
      pages: [
        { path: '/guide/1-are-you-ready/1-first-time-buyer/', label: 'First-Time Buyer' },
        { path: '/guide/1-are-you-ready/2-rent-vs-buy/', label: 'Rent vs. Buy' },
        { path: '/guide/1-are-you-ready/3-credit-score/', label: 'Credit Score' },
        { path: '/guide/1-are-you-ready/4-stress-test/', label: 'Stress Test' },
        { path: '/guide/1-are-you-ready/5-financial-checklist/', label: 'Financial Checklist' },
        { path: '/guide/1-are-you-ready/6-co-buying/', label: 'Co-Buying' },
      ],
    },
    {
      name: 'Module 2: Saving Smart',
      pages: [
        { path: '/guide/2-saving-smart/1-fhsa/', label: 'FHSA' },
        { path: '/guide/2-saving-smart/2-rrsp-hbp/', label: 'RRSP HBP' },
        { path: '/guide/2-saving-smart/3-combined-strategy/', label: 'Combined Strategy' },
        { path: '/guide/2-saving-smart/4-tfsa/', label: 'TFSA' },
        { path: '/guide/2-saving-smart/5-saving-timelines/', label: 'Saving Timelines' },
        { path: '/guide/2-saving-smart/6-common-mistakes/', label: 'Common Mistakes' },
      ],
    },
    {
      name: 'Module 3: Down Payments & Mortgages',
      pages: [
        { path: '/guide/3-down-payments-mortgages/1-down-payment-rules/', label: 'Down Payment Rules' },
        { path: '/guide/3-down-payments-mortgages/2-cmhc-insurance/', label: 'CMHC Insurance' },
        { path: '/guide/3-down-payments-mortgages/3-fixed-vs-variable/', label: 'Fixed vs. Variable' },
        { path: '/guide/3-down-payments-mortgages/4-amortization/', label: 'Amortization' },
        { path: '/guide/3-down-payments-mortgages/5-pre-approval/', label: 'Pre-Approval' },
        { path: '/guide/3-down-payments-mortgages/6-gds-tds-ratios/', label: 'GDS & TDS Ratios' },
        { path: '/guide/3-down-payments-mortgages/7-choosing-provider/', label: 'Choosing a Provider' },
        { path: '/guide/3-down-payments-mortgages/8-self-employed/', label: 'Self-Employed' },
      ],
    },
    {
      name: 'Module 4: Government Programs',
      pages: [
        { path: '/guide/4-government-programs/1-federal-programs/', label: 'Federal Programs' },
        { path: '/guide/4-government-programs/2-ontario/', label: 'Ontario' },
        { path: '/guide/4-government-programs/3-british-columbia/', label: 'British Columbia' },
        { path: '/guide/4-government-programs/4-alberta-prairies/', label: 'Alberta & Prairies' },
        { path: '/guide/4-government-programs/5-quebec/', label: 'Quebec' },
        { path: '/guide/4-government-programs/6-atlantic-canada/', label: 'Atlantic Canada' },
        { path: '/guide/4-government-programs/7-program-comparison/', label: 'Program Comparison' },
        { path: '/guide/4-government-programs/8-territories/', label: 'Territories' },
      ],
    },
    {
      name: 'Module 5: Finding a Home',
      pages: [
        { path: '/guide/5-finding-a-home/0-your-team/', label: 'Your Home-Buying Team' },
        { path: '/guide/5-finding-a-home/1-working-with-realtor/', label: 'Working with a Realtor' },
        { path: '/guide/5-finding-a-home/2-reading-mls-listings/', label: 'Reading MLS Listings' },
        { path: '/guide/5-finding-a-home/3-condo-vs-freehold/', label: 'Condo vs. Freehold' },
        { path: '/guide/5-finding-a-home/4-showings-guide/', label: 'Showings Guide' },
        { path: '/guide/5-finding-a-home/5-school-catchment/', label: 'School Catchment' },
        { path: '/guide/5-finding-a-home/6-red-flags/', label: 'Red Flags' },
        { path: '/guide/5-finding-a-home/7-new-construction/', label: 'New Construction' },
      ],
    },
    {
      name: 'Module 6: Making an Offer',
      pages: [
        { path: '/guide/6-making-an-offer/1-purchase-agreement/', label: 'Purchase Agreement' },
        { path: '/guide/6-making-an-offer/2-conditions/', label: 'Conditions' },
        { path: '/guide/6-making-an-offer/3-bidding-wars/', label: 'Bidding Wars' },
        { path: '/guide/6-making-an-offer/4-home-inspection/', label: 'Home Inspection' },
        { path: '/guide/6-making-an-offer/5-deposits/', label: 'Deposits' },
        { path: '/guide/6-making-an-offer/6-offer-mistakes/', label: 'Offer Mistakes' },
      ],
    },
    {
      name: 'Module 7: Closing the Deal',
      pages: [
        { path: '/guide/7-closing-the-deal/1-closing-costs-overview/', label: 'Closing Costs Overview' },
        { path: '/guide/7-closing-the-deal/2-cost-breakdown/', label: 'Cost Breakdown' },
        { path: '/guide/7-closing-the-deal/3-land-transfer-tax/', label: 'Land Transfer Tax' },
        { path: '/guide/7-closing-the-deal/4-real-estate-lawyer/', label: 'Real Estate Lawyer' },
        { path: '/guide/7-closing-the-deal/5-title-insurance/', label: 'Title Insurance' },
        { path: '/guide/7-closing-the-deal/6-closing-day/', label: 'Closing Day' },
        { path: '/guide/7-closing-the-deal/7-closing-example/', label: 'Closing Example' },
      ],
    },
    {
      name: 'Module 8: Life After Closing',
      pages: [
        { path: '/guide/8-life-after-closing/1-emergency-fund/', label: 'Emergency Fund' },
        { path: '/guide/8-life-after-closing/2-property-taxes/', label: 'Property Taxes' },
        { path: '/guide/8-life-after-closing/3-home-insurance/', label: 'Home Insurance' },
        { path: '/guide/8-life-after-closing/4-mortgage-renewal/', label: 'Mortgage Renewal' },
        { path: '/guide/8-life-after-closing/5-home-maintenance/', label: 'Home Maintenance' },
        { path: '/guide/8-life-after-closing/6-energy-efficiency/', label: 'Energy Efficiency' },
        { path: '/guide/8-life-after-closing/7-building-equity/', label: 'Building Equity' },
        { path: '/guide/8-life-after-closing/8-congratulations/', label: 'Congratulations' },
      ],
    },
    {
      name: 'Reference',
      pages: [
        { path: '/guide/faq/', label: 'FAQ' },
        { path: '/guide/glossary/', label: 'Glossary' },
      ],
    },
  ];

  const ALL_PAGES = GUIDE_MODULES.flatMap((m) => m.pages.map((p) => p.path));
  const TOTAL_PAGES = ALL_PAGES.length;

  function getVisited(): Set<string> {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      return stored ? new Set(JSON.parse(stored)) : new Set();
    } catch {
      return new Set();
    }
  }

  function saveVisited(visited: Set<string>) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...visited]));
    } catch {
      // localStorage may be unavailable
    }
  }

  function init() {
    const widget = document.getElementById('guide-progress');
    if (!widget) return;

    const currentPath = window.location.pathname;
    const visited = getVisited();

    // Record current page if it's a guide page
    if (ALL_PAGES.includes(currentPath)) {
      visited.add(currentPath);
      saveVisited(visited);
    }

    const visitedCount = ALL_PAGES.filter((p) => visited.has(p)).length;
    const percent = TOTAL_PAGES > 0 ? Math.round((visitedCount / TOTAL_PAGES) * 100) : 0;

    // Update summary text
    const textEl = widget.querySelector('.guide-progress-text');
    if (textEl) {
      textEl.textContent = `${visitedCount} of ${TOTAL_PAGES} pages read`;
    }

    // Update progress bar
    const barFill = widget.querySelector('.guide-progress-bar-fill') as HTMLElement;
    if (barFill) {
      barFill.style.width = `${percent}%`;
    }

    // Build module details
    const modulesContainer = document.getElementById('guide-progress-modules');
    if (modulesContainer) {
      modulesContainer.innerHTML = GUIDE_MODULES.map((mod) => {
        const firstPage = mod.pages[0]?.path || '#';
        const pagesHtml = mod.pages
          .map((page) => {
            const isVisited = visited.has(page.path);
            const isActive = page.path === currentPath;
            const classes = ['guide-progress-page-link'];
            if (isVisited) classes.push('visited');
            if (isActive) classes.push('active');
            const statusClass = isVisited ? 'done' : 'not-done';
            const statusChar = isVisited ? '✓' : '✗';
            return `<a href="${page.path}" class="${classes.join(' ')}"><span class="guide-progress-status ${statusClass}">${statusChar}</span><span>${page.label}</span></a>`;
          })
          .join('');
        return `<div class="guide-progress-module"><div class="guide-progress-module-header"><a href="${firstPage}">${mod.name}</a></div>${pagesHtml}</div>`;
      }).join('');
    }

    // Toggle details
    const toggleBtn = document.getElementById('guide-progress-toggle');
    const details = document.getElementById('guide-progress-details');
    if (toggleBtn && details) {
      // Remove old listener by cloning
      const newToggle = toggleBtn.cloneNode(true) as HTMLElement;
      toggleBtn.parentNode?.replaceChild(newToggle, toggleBtn);
      newToggle.addEventListener('click', () => {
        const expanded = newToggle.getAttribute('aria-expanded') === 'true';
        newToggle.setAttribute('aria-expanded', String(!expanded));
        details.hidden = expanded;
      });
    }

    // Reset button
    const resetBtn = document.getElementById('guide-progress-reset');
    if (resetBtn) {
      const newReset = resetBtn.cloneNode(true) as HTMLElement;
      resetBtn.parentNode?.replaceChild(newReset, resetBtn);
      newReset.addEventListener('click', (e) => {
        e.stopPropagation();
        if (window.confirm('Reset all guide progress? This cannot be undone.')) {
          localStorage.removeItem(STORAGE_KEY);
          init();
        }
      });
    }
  }

  // Run on initial load and on Astro page transitions
  init();
  document.addEventListener('astro:page-load', init);
</script>
